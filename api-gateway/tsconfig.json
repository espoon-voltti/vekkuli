{
  "compilerOptions": {
    "esModuleInterop": true,
    "module": "node16",
    "moduleResolution": "node16",
    "noEmit": false,
    "noEmitOnError": true,
    "rootDir": "src",
    "outDir": "dist",
    "sourceMap": true,
    "strict": true,
    "target": "es2022"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    ".git",
    "node_modules",
    "dist"
  ]
}
